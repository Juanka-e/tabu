# Database
DATABASE_URL="mysql://root:@localhost:3306/tabu2"

# NextAuth
AUTH_SECRET="replace_with_a_strong_random_value_at_least_32_chars"
NEXTAUTH_URL="http://localhost:3000"
# Production benzeri localhost testlerinde Auth.js host trust hatasi almamak icin:
# AUTH_TRUST_HOST="true"
# Reverse proxy / custom host kullaniminda bunu bilinclı sekilde ac.
AUTH_TRUST_HOST="false"

# App
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NODE_ENV="development"
WORD_POOL_SIZE=120
ADMIN_TIMEOUT_MS=180000
PLAYER_TIMEOUT_MS=15000
TRUST_PROXY=false

# Rate Limiting (set to "false" to disable for testing)
RATE_LIMIT_ENABLED=false
ROOM_JOIN_MAX_ATTEMPTS=1000
ROOM_JOIN_WINDOW_SECONDS=60

# Captcha Providers
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

# Admin Access Gateway Policy
# ADMIN_ACCESS_MODE:
# - public_login: mevcut uygulama ici admin login davranisi
# - restricted_login: admin login / admin API sadece ek policy saglanirsa acik
# - external_gateway: admin yuzeyi harici gateway/Zero Trust arkasi icin optimize mod
ADMIN_ACCESS_MODE="public_login"

# Production'da policy eksikse admin yuzeyini kapatmak icin "true" kullan.
# Local gelistirmede genelde "false" gerekmez; varsayilan local bypass ile rahat calisir.
ADMIN_ACCESS_FAIL_CLOSED="true"

# Localhost / 127.0.0.1 isteklerini development ortaminda policy disi birak.
# Production'da etkisi yoktur.
ADMIN_ACCESS_ALLOW_LOCAL_DEV_BYPASS="true"

# Harici gateway bir sabit header birakiyorsa kullan.
# Ornek:
# ADMIN_ACCESS_HEADER_NAME="x-admin-access"
# ADMIN_ACCESS_HEADER_VALUE="approved"
ADMIN_ACCESS_HEADER_NAME=""
ADMIN_ACCESS_HEADER_VALUE=""

# Cloudflare Zero Trust gibi sistemler kullanici email'ini header ile gecirebilir.
# Header adini burada belirt, izinli email veya domainleri asagida tanimla.
# Ornek:
# ADMIN_ACCESS_EMAIL_HEADER_NAME="cf-access-authenticated-user-email"
ADMIN_ACCESS_EMAIL_HEADER_NAME=""

# Virgulle ayrilmis tam email allowlist.
# Ornek: "admin@firma.com,ops@firma.com"
ADMIN_ACCESS_ALLOWED_EMAILS=""

# Virgulle ayrilmis domain allowlist.
# Ornek: "firma.com,internal.firma.com"
ADMIN_ACCESS_ALLOWED_EMAIL_DOMAINS=""

